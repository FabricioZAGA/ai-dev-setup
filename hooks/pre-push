#!/usr/bin/env bash
# Git hook: pre-push
# Validates branch naming against the configured pattern.
# Installed by ai-dev-setup — https://github.com/FabricioZAGA/ai-dev-setup

CONFIG_FILE="$HOME/.dev-setup-config"
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Never block main/master/develop pushes
if [[ "$BRANCH" =~ ^(main|master|develop|staging|release/.*)$ ]]; then
  exit 0
fi

PATTERN="${BRANCH_PATTERN:-{username}/{ticket}/{description}}"

# Convert user-friendly pattern into a regex
build_regex() {
  local pattern="$1"
  local user="${GITHUB_USER:-[a-zA-Z0-9_\-]+}"

  # Replace tokens with regex segments
  pattern="${pattern//\{username\}/$user}"
  pattern="${pattern//\{ticket\}/[A-Z][A-Z0-9]+-[0-9]+}"
  pattern="${pattern//\{type\}/(feat|fix|test|refactor|chore|docs|ci|perf|build|revert)}"
  pattern="${pattern//\{description\}/[a-z0-9][a-z0-9\-]+}"

  # Escape dots
  pattern="${pattern//./\\.}"
  echo "^${pattern}$"
}

REGEX=$(build_regex "$PATTERN")

if ! echo "$BRANCH" | grep -qE "$REGEX"; then
  echo ""
  echo "  ✗  Branch name does not match your configured pattern."
  echo ""
  echo "  Pattern:  $PATTERN"
  echo "  Example:  $(echo "$PATTERN" \
    | sed "s/{username}/${GITHUB_USER:-yourname}/g" \
    | sed "s/{ticket}/FIRE-123/g" \
    | sed "s/{type}/feat/g" \
    | sed "s/{description}/short-description/g")"
  echo ""
  echo "  Your branch: $BRANCH"
  echo ""
  echo "  Rename with: git branch -m $BRANCH <new-name>"
  echo "  To skip this check: git push --no-verify"
  echo ""
  exit 1
fi

exit 0
