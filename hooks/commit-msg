#!/usr/bin/env bash
# Git hook: commit-msg
# Validates conventional commit format.
# Installed by ai-dev-setup — https://github.com/FabricioZAGA/ai-dev-setup

CONFIG_FILE="$HOME/.dev-setup-config"
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# Skip if conventional commits not enabled
if [[ "${USE_CONVENTIONAL_COMMITS:-true}" != "true" ]]; then
  exit 0
fi

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits, fixup!, squash!
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert|fixup!|squash!)"; then
  exit 0
fi

# Skip WIP commits (allow during development)
if echo "$COMMIT_MSG" | grep -qiE "^WIP"; then
  exit 0
fi

ALLOWED_TYPES="${COMMIT_TYPES:-feat|fix|test|refactor|chore|docs|ci|perf|build|revert}"
PATTERN="^(${ALLOWED_TYPES})(\([a-zA-Z0-9_\-]+\))?(!)?:\s.{1,100}$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "  ✗  Invalid commit message format."
  echo ""
  echo "  Expected: type(scope): subject"
  echo "  Example:  feat(auth): add OAuth2 login"
  echo "            fix(api): handle null response from licensing"
  echo "            test(vip): add kafka event assertions"
  echo ""
  echo "  Allowed types: $(echo "$ALLOWED_TYPES" | tr '|' ', ')"
  echo ""
  echo "  Your message: $COMMIT_MSG"
  echo ""
  echo "  Tip: use 'git commit --amend' to fix the message."
  echo "  To skip this check (not recommended): git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
